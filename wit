# ── router ────────────────────────────────────────────────────────────────────
local cmd=${1:-help}
shift 2>/dev/null || true

case $cmd in
  init)   cmd_init "$@"   ;;
  new)    cmd_new "$@"    ;;
  work)   cmd_work "$@"   ;;
  event)  cmd_event "$@"  ;;
  score)  cmd_score "$@"  ;;
  commit) cmd_commit "$@" ;;
  log)    cmd_log "$@"    ;;
  status) cmd_status "$@" ;;
  help|--help|-h) cmd_help ;;
  *) _err "Unknown command: $cmd\nRun: wit help" ;;
esac
