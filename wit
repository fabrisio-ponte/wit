#!/usr/bin/env zsh
# wit — skill tracking CLI
# mirrors git's vocabulary, sits alongside it
# usage: wit new <slug> [tags...]  |  wit commit  |  wit log  |  wit status

set -euo pipefail

# ── colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── helpers ───────────────────────────────────────────────────────────────────
_info()    { print -P "%F{cyan}→%f $*" }
_ok()      { print -P "%F{green}✓%f $*" }
_warn()    { print -P "%F{yellow}⚠%f $*" }
_err()     { print -P "%F{red}✗%f $*" >&2; exit 1 }
_section() { print -P "\n%B%F{blue}$*%f%b" }

# ── repo root detection ───────────────────────────────────────────────────────
_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

_wit_root() {
  local root
  root=$(_repo_root) || _err "Not inside a git repo. Run: git init"
  echo "$root"
}

_latest_open_session() {
  local root=$1
  local session_dir=""
  local latest_time=0

  for d in "$root/sessions"/*/; do
    [[ -f "$d/meta.json" ]] || continue
    local rel="sessions/$(basename "$d")"
    if git -C "$root" status --porcelain "$rel" | grep -q .; then
      local mtime=$(stat -f %m "$d/meta.json" 2>/dev/null || stat -c %Y "$d/meta.json" 2>/dev/null)
      if (( mtime > latest_time )); then
        latest_time=$mtime
        session_dir=$d
      fi
    fi
  done

  [[ -n "$session_dir" ]] && echo "$session_dir"
}

_clamp_1_10() {
  local n=$1
  (( n < 1 )) && n=1
  (( n > 10 )) && n=10
  echo "$n"
}

_extract_section() {
  local file=$1
  local header=$2
  [[ -f "$file" ]] || return 0
  awk -v h="$header" '
    BEGIN { in_section=0 }
    $0 ~ "^##[[:space:]]+" h "[[:space:]]*$" { in_section=1; next }
    /^##[[:space:]]+/ { if (in_section) exit }
    { if (in_section) print }
  ' "$file"
}

_word_count_text() {
  local text=$1
  print -r -- "$text" | tr -cs '[:alnum:]' '\n' | awk 'NF { c++ } END { print c+0 }'
}

_nonempty_lines_file() {
  local file=$1
  [[ -f "$file" ]] || { echo 0; return; }
  grep -cve '^[[:space:]]*$' "$file" 2>/dev/null || echo 0
}

_token_overlap_percent() {
  local a=$1
  local b=$2
  local fa=$(mktemp)
  local fb=$(mktemp)
  print -r -- "$a" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '\n' | awk 'length($0)>=3' | sort -u > "$fa"
  print -r -- "$b" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '\n' | awk 'length($0)>=3' | sort -u > "$fb"

  local common=$(comm -12 "$fa" "$fb" | wc -l | tr -d ' ')
  local total=$(cat "$fa" "$fb" | sort -u | wc -l | tr -d ' ')
  rm -f "$fa" "$fb"

  if (( total == 0 )); then
    echo 50
    return
  fi

  echo $(( (common * 100) / total ))
}

_score_session_heuristic() {
  local session_dir=$1
  local meta="$session_dir/meta.json"
  local prompt_file="$session_dir/prompt.md"
  local final_file="$session_dir/output_final.txt"
  local reflection_file="$session_dir/reflection.md"
  local events_file="$session_dir/events.jsonl"

  local goal_text=$(_extract_section "$prompt_file" "goal")
  local prompt_text=$(_extract_section "$prompt_file" "prompt")
  local followups_text=$(_extract_section "$prompt_file" "followups")
  local final_text=""
  [[ -f "$final_file" ]] && final_text=$(cat "$final_file")

  local goal_words=$(_word_count_text "$goal_text")
  local prompt_words=$(_word_count_text "$prompt_text")
  local followups_words=$(_word_count_text "$followups_text")
  local final_lines=$(_nonempty_lines_file "$final_file")

  local prompt_score=5
  (( goal_words >= 5 )) && (( prompt_score += 1 )) || (( prompt_score -= 1 ))
  (( prompt_words >= 25 )) && (( prompt_score += 1 ))
  (( prompt_words >= 70 )) && (( prompt_score += 1 ))
  print -r -- "$prompt_text" | grep -Eiq '(must|should|acceptance|criteria|output|format|constraint)' && (( prompt_score += 1 ))
  print -r -- "$prompt_text" | grep -Eiq '(language|framework|stack|api|file|test)' && (( prompt_score += 1 ))
  (( followups_words > 0 )) && (( prompt_score += 1 ))
  prompt_score=$(_clamp_1_10 "$prompt_score")

  local code_score=5
  (( final_lines >= 8 )) && (( code_score += 1 ))
  (( final_lines >= 25 )) && (( code_score += 1 ))

  local worked_text=$(_extract_section "$reflection_file" "what worked")
  local failed_text=$(_extract_section "$reflection_file" "what failed")
  local pattern_text=$(_extract_section "$reflection_file" "pattern noticed")
  local next_text=$(_extract_section "$reflection_file" "next experiment")
  (( $(_word_count_text "$worked_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$failed_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$pattern_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$next_text") > 0 )) && (( code_score += 1 ))

  local pass_events=0
  local fail_events=0
  if [[ -f "$events_file" ]]; then
    pass_events=$(grep -Ec '"event":"(test.pass|build.pass)"' "$events_file" || true)
    fail_events=$(grep -Ec '"event":"(test.fail|build.fail)"' "$events_file" || true)
  fi
  (( pass_events > 0 )) && (( code_score += 1 ))
  (( fail_events > 0 )) && (( code_score -= 1 ))

  local first_kept=$(jq -r '.first_output_kept' "$meta")
  [[ "$first_kept" == "true" ]] && (( code_score += 1 ))

  local delta=$(jq -r '.delta_from_raw' "$meta")
  if [[ "$delta" != "null" ]]; then
    if (( delta <= 3 )); then
      (( code_score += 1 ))
    elif (( delta >= 10 )); then
      (( code_score -= 1 ))
    fi
  fi

  local iterations=$(jq -r '.iterations' "$meta")
  if [[ "$iterations" != "null" ]]; then
    (( iterations <= 2 )) && (( code_score += 1 ))
    (( iterations >= 6 )) && (( code_score -= 1 ))
  fi

  code_score=$(_clamp_1_10 "$code_score")

  local overlap=$(_token_overlap_percent "$goal_text" "$final_text")
  local drift_score=$(( overlap / 10 ))
  (( drift_score == 0 )) && drift_score=1
  print -r -- "$failed_text" | grep -Eiq '(drift|scope creep|changed direction|off track)' && (( drift_score -= 1 ))
  drift_score=$(_clamp_1_10 "$drift_score")

  local session_score=$(( (prompt_score + code_score + drift_score) / 3 ))
  session_score=$(_clamp_1_10 "$session_score")

  local reason="heuristic: prompt_words=$prompt_words, final_lines=$final_lines, overlap=${overlap}%, pass_events=$pass_events, fail_events=$fail_events"

  local tmp=$(mktemp)
  jq \
    --argjson ps "$prompt_score" \
    --argjson cs "$code_score" \
    --argjson ds "$drift_score" \
    --argjson ss "$session_score" \
    --arg mode "heuristic" \
    --arg reason "$reason" \
    '.prompt_score=$ps
    | .code_score=$cs
    | .drift_score=$ds
    | .session_score=$ss
    | .scoring_mode=$mode
    | .score_reasoning=$reason' \
    "$meta" > "$tmp" && mv "$tmp" "$meta"
}

# ── wit init ──────────────────────────────────────────────────────────────────
cmd_init() {
  local root=${1:-$PWD}
  _section "Initialising wit in $root"

  mkdir -p "$root/sessions"
  mkdir -p "$root/metrics"

  # scores.jsonl — the database
  if [[ ! -f "$root/metrics/scores.jsonl" ]]; then
    touch "$root/metrics/scores.jsonl"
    _ok "Created metrics/scores.jsonl"
  fi

  # trends.md — human-readable summary, updated by wit log
  if [[ ! -f "$root/metrics/trends.md" ]]; then
    cat > "$root/metrics/trends.md" <<'EOF'
# Trends

Updated automatically by `wit log`.

## Summary
_No sessions committed yet._
EOF
    _ok "Created metrics/trends.md"
  fi

  # README
  if [[ ! -f "$root/README.md" ]]; then
    cat > "$root/README.md" <<'EOF'
# skill-tracker

A git-based log of prompt and code quality over time.

## workflow
```
wit new <slug> [tags...]   # start a session
wit work                   # record terminal work into current session
wit event <name> [value]   # append a structured event to current session
wit commit                 # score + commit
wit log                    # view history
wit status                 # current open session
```

## session structure
```
sessions/YYYY-MM-DD_<slug>/
  prompt.md        — the exact prompt sent
  output_raw.*     — claude's output, unedited
  output_final.*   — what you actually kept
  meta.json        — scores, tags, timing
  reflection.md    — what worked / failed
```
EOF
    _ok "Created README.md"
  fi

  # initial commit if repo is empty
  if ! git -C "$root" log --oneline -1 &>/dev/null; then
    git -C "$root" add .
    git -C "$root" commit -m "init: wit scaffold"
    _ok "Initial commit done"
  fi

  _ok "wit ready. Start your first session with: wit new <slug> [tags...]"
}

# ── wit work ──────────────────────────────────────────────────────────────────
cmd_work() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  command -v script &>/dev/null || _err "Missing 'script' command; cannot record terminal transcript"

  local log_file="$session_dir/terminal_work.log"
  local slug=$(jq -r '.slug' "$session_dir/meta.json")

  _section "Recording terminal work for: $slug"
  _info "Transcript file: ${log_file#$root/}"
  _info "Type 'exit' to stop recording and return to your shell"

  # script opens a nested interactive shell and records commands + output.
  script -q "$log_file"

  _ok "Saved terminal transcript: ${log_file#$root/}"
}

# ── wit event ─────────────────────────────────────────────────────────────────
cmd_event() {
  [[ $# -lt 1 ]] && _err "Usage: wit event <name> [value]\n  e.g. wit event test.pass\n  e.g. wit event file.change src/app.ts"

  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local event_name=$1
  shift
  local event_value="${*:-}"
  local event_file="$session_dir/events.jsonl"
  local ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local session_slug=$(jq -r '.slug' "$session_dir/meta.json")

  local event_line
  if [[ -n "$event_value" ]]; then
    event_line=$(jq -nc \
      --arg ts "$ts" \
      --arg event "$event_name" \
      --arg value "$event_value" \
      --arg slug "$session_slug" \
      '{ts:$ts,event:$event,value:$value,slug:$slug}')
  else
    event_line=$(jq -nc \
      --arg ts "$ts" \
      --arg event "$event_name" \
      --arg slug "$session_slug" \
      '{ts:$ts,event:$event,slug:$slug}')
  fi

  echo "$event_line" >> "$event_file"
  _ok "Event saved: $event_name${event_value:+ ($event_value)}"
}

# ── wit new ───────────────────────────────────────────────────────────────────
cmd_new() {
  [[ $# -lt 1 ]] && _err "Usage: wit new <slug> [tags...]\n  e.g. wit new auth-flow backend jwt"

  local root=$(_wit_root)
  local slug=$1; shift
  local tags=("$@")
  local date=$(date +%Y-%m-%d)
  local dir="$root/sessions/${date}_${slug}"

  [[ -d "$dir" ]] && _err "Session already exists: $dir"

  _section "New session: $slug"
  mkdir -p "$dir"

  # ── prompt.md ──
  cat > "$dir/prompt.md" <<EOF
# $slug
_${date}_

## goal
<!-- one sentence: what are you trying to build? -->

## prompt
<!-- paste the exact prompt you sent — no cleanup -->

## followups
<!-- any clarifying prompts you sent after (leave blank if none) -->
EOF

  # ── meta.json ──
  local tags_json
  if [[ ${#tags[@]} -gt 0 ]]; then
    tags_json=$(printf '"%s",' "${tags[@]}" | sed 's/,$//')
    tags_json="[$tags_json]"
  else
    tags_json='[]'
  fi

  cat > "$dir/meta.json" <<EOF
{
  "date": "$date",
  "slug": "$slug",
  "skill_areas": $tags_json,
  "prompt_score": null,
  "code_score": null,
  "drift_score": null,
  "session_score": null,
  "delta_from_raw": null,
  "iterations": null,
  "time_mins": null,
  "first_output_kept": null,
  "scoring_mode": null,
  "score_reasoning": null
}
EOF

  # ── output files ──
  touch "$dir/output_raw.txt"
  touch "$dir/output_final.txt"

  # ── reflection.md ──
  cat > "$dir/reflection.md" <<EOF
# reflection — $slug
_${date}_

## what worked
<!-- prompt patterns or framing that landed well -->

## what failed
<!-- where the prompt was vague, where code needed fixing -->

## pattern noticed
<!-- any recurring signal across sessions (optional) -->

## next experiment
<!-- one concrete thing to try differently next time -->
EOF

  _ok "Scaffolded: sessions/${date}_${slug}/"
  _info "Fill in the files, then run: wit commit"

  # open in VS Code
  if command -v code &>/dev/null; then
    code "$dir"
    _ok "Opened in VS Code"
  else
    _warn "VS Code CLI (code) not found — open the folder manually"
    _info "$dir"
  fi
}

# ── wit score ─────────────────────────────────────────────────────────────────
cmd_score() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local meta="$session_dir/meta.json"
  local slug=$(jq -r '.slug' "$meta")

  _section "Auto-scoring session: $slug"
  _score_session_heuristic "$session_dir"

  local prompt_score=$(jq -r '.prompt_score' "$meta")
  local code_score=$(jq -r '.code_score' "$meta")
  local drift_score=$(jq -r '.drift_score' "$meta")
  local session_score=$(jq -r '.session_score' "$meta")

  _ok "Scores updated (heuristic)"
  _info "prompt ${prompt_score}/10 · code ${code_score}/10 · drift ${drift_score}/10 · session ${session_score}/10"
}

# ── wit commit ────────────────────────────────────────────────────────────────
cmd_commit() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No uncommitted session found. Start one with: wit new <slug>"

  local meta="$session_dir/meta.json"
  local slug=$(jq -r '.slug' "$meta")
  local date=$(jq -r '.date' "$meta")

  _section "Committing session: $slug"

  # ── auto-score first for lightweight default workflow ──
  local prompt_score=$(jq -r '.prompt_score' "$meta")
  local code_score=$(jq -r '.code_score' "$meta")
  if [[ "$prompt_score" == "null" || "$code_score" == "null" ]]; then
    _info "Auto-scoring with heuristic model..."
    _score_session_heuristic "$session_dir"
  fi

  # ── interactive scoring only if nulls remain ──
  local prompt_score=$(jq -r '.prompt_score' "$meta")
  local code_score=$(jq -r '.code_score' "$meta")
  local drift_score=$(jq -r '.drift_score' "$meta")
  local session_score=$(jq -r '.session_score' "$meta")
  local iterations=$(jq -r '.iterations' "$meta")
  local time_mins=$(jq -r '.time_mins' "$meta")
  local first_kept=$(jq -r '.first_output_kept' "$meta")
  local delta=$(jq -r '.delta_from_raw' "$meta")

  _prompt_score() {
    local field=$1 label=$2 current=$3
    if [[ "$current" == "null" ]]; then
      print -n "  $label (1-10): "
      read val
      echo "$val"
    else
      echo "$current"
    fi
  }

  if [[ "$prompt_score" == "null" ]]; then
    print -P "\n%B%F{yellow}Score this session:%f%b"
    print -n "  prompt clarity (1-10): "; read prompt_score
    print -n "  code quality  (1-10): "; read code_score
    print -n "  iterations needed:    "; read iterations
    print -n "  time (mins):          "; read time_mins
    print -n "  first output kept? (true/false): "; read first_kept
    print -n "  edits made to raw output (0=none): "; read delta

    # write back to meta.json
    local tmp=$(mktemp)
    jq \
      --argjson ps "$prompt_score" \
      --argjson cs "$code_score" \
      --argjson it "$iterations" \
      --argjson tm "$time_mins" \
      --argjson fk "$first_kept" \
      --argjson dr "$delta" \
      '.prompt_score=$ps | .code_score=$cs | .iterations=$it | .time_mins=$tm | .first_output_kept=$fk | .delta_from_raw=$dr' \
      "$meta" > "$tmp" && mv "$tmp" "$meta"
    _ok "Scores written to meta.json"
  fi

  # refresh in case manual entry happened above
  prompt_score=$(jq -r '.prompt_score' "$meta")
  code_score=$(jq -r '.code_score' "$meta")
  drift_score=$(jq -r '.drift_score' "$meta")
  session_score=$(jq -r '.session_score' "$meta")
  iterations=$(jq -r '.iterations' "$meta")
  time_mins=$(jq -r '.time_mins' "$meta")
  first_kept=$(jq -r '.first_output_kept' "$meta")
  delta=$(jq -r '.delta_from_raw' "$meta")

  # ── append to scores.jsonl ──
  local areas=$(jq -c '.skill_areas' "$meta")
  local scoring_mode=$(jq -r '.scoring_mode // "manual"' "$meta")
  local score_reasoning=$(jq -r '.score_reasoning // ""' "$meta")
  local score_line=$(jq -nc \
    --arg date "$date" \
    --arg slug "$slug" \
    --argjson ps "$prompt_score" \
    --argjson cs "$code_score" \
    --argjson ds "$drift_score" \
    --argjson ss "$session_score" \
    --argjson it "$iterations" \
    --argjson tm "$time_mins" \
    --argjson fk "$first_kept" \
    --argjson dr "$delta" \
    --arg mode "$scoring_mode" \
    --arg reason "$score_reasoning" \
    --argjson areas "$areas" \
    '{date:$date,slug:$slug,prompt_score:$ps,code_score:$cs,drift_score:$ds,session_score:$ss,iterations:$it,time_mins:$tm,first_output_kept:$fk,delta_from_raw:$dr,scoring_mode:$mode,score_reasoning:$reason,skill_areas:$areas}')

  echo "$score_line" >> "$root/metrics/scores.jsonl"
  _ok "Appended to metrics/scores.jsonl"

  # ── git commit ──
  local areas_flat=$(jq -r '.skill_areas[]?' "$meta" | tr '\n' ' ' | sed 's/ $//')
  local msg="session: $date | $slug | prompt ${prompt_score}/10 code ${code_score}/10"
  [[ -n "$areas_flat" ]] && msg="$msg | $areas_flat"

  git -C "$root" add .
  git -C "$root" commit -m "$msg"
  _ok "git commit: $msg"
}

# ── wit log ───────────────────────────────────────────────────────────────────
cmd_log() {
  local root=$(_wit_root)
  local scores="$root/metrics/scores.jsonl"

  [[ ! -f "$scores" ]] && _err "No scores.jsonl found. Run wit init first."
  [[ ! -s "$scores" ]]  && { _warn "No sessions committed yet."; return; }

  _section "Session history"

  local count=0
  local total_prompt=0
  local total_code=0

  while IFS= read -r line; do
    local date=$(echo "$line" | jq -r '.date')
    local slug=$(echo "$line" | jq -r '.slug')
    local ps=$(echo "$line"   | jq -r '.prompt_score')
    local cs=$(echo "$line"   | jq -r '.code_score')
    local it=$(echo "$line"   | jq -r '.iterations')
    local tm=$(echo "$line"   | jq -r '.time_mins')
    local areas=$(echo "$line" | jq -r '.skill_areas[]?' | tr '\n' ' ')

    # score colour
    local p_col=$RESET
    local c_col=$RESET
    (( ps >= 8 )) && p_col=$GREEN || (( ps >= 6 )) && p_col=$YELLOW || p_col=$RED
    (( cs >= 8 )) && c_col=$GREEN || (( cs >= 6 )) && c_col=$YELLOW || c_col=$RED

    printf "  ${DIM}%s${RESET}  ${BOLD}%-24s${RESET}  prompt ${p_col}%2s/10${RESET}  code ${c_col}%2s/10${RESET}  ${DIM}%s iter · %s min · %s${RESET}\n" \
      "$date" "$slug" "$ps" "$cs" "$it" "$tm" "$areas"

    (( count++ ))
    (( total_prompt += ps ))
    (( total_code   += cs ))
  done < "$scores"

  # averages
  if (( count > 0 )); then
    local avg_p=$(echo "scale=1; $total_prompt / $count" | bc)
    local avg_c=$(echo "scale=1; $total_code   / $count" | bc)
    _section "Averages across $count sessions"
    printf "  prompt %.1f/10   code %.1f/10\n" "$avg_p" "$avg_c"
  fi

  # trend (last 5 vs previous 5)
  if (( count >= 6 )); then
    _section "Trend (last 5 vs previous 5)"
    local last5=$(tail -5  "$scores" | jq -s '[.[].prompt_score] | add/length')
    local prev5=$(tail -10 "$scores" | head -5 | jq -s '[.[].prompt_score] | add/length')
    local diff=$(echo "scale=1; $last5 - $prev5" | bc)
    if (( $(echo "$diff > 0" | bc -l) )); then
      printf "  prompt ${GREEN}+%s${RESET} vs prior 5 sessions\n" "$diff"
    elif (( $(echo "$diff < 0" | bc -l) )); then
      printf "  prompt ${RED}%s${RESET} vs prior 5 sessions\n" "$diff"
    else
      printf "  prompt ${DIM}flat${RESET} vs prior 5 sessions\n"
    fi
  fi
}

# ── wit status ────────────────────────────────────────────────────────────────
cmd_status() {
  local root=$(_wit_root)

  _section "wit status"

  # uncommitted session folders
  local found=0
  for d in "$root/sessions"/*/; do
    [[ -f "$d/meta.json" ]] || continue
    local rel="sessions/$(basename $d)"
    if git -C "$root" status --porcelain "$rel" | grep -q .; then
      local slug=$(jq -r '.slug' "$d/meta.json")
      local ps=$(jq -r '.prompt_score' "$d/meta.json")
      _info "Open session: ${BOLD}$slug${RESET} $([ "$ps" = "null" ] && echo "${YELLOW}(not yet scored)${RESET}" || echo "prompt ${ps}/10")"
      found=1
    fi
  done

  (( found == 0 )) && _ok "Nothing open. Start one with: wit new <slug> [tags...]"

  # quick git status
  echo ""
  git -C "$root" status --short
}

