  _install_prompt_provenance_instructions "$root"
  _ok "Prompt provenance instructions ensured in repo"
}

# ── wit work ──────────────────────────────────────────────────────────────────
cmd_work() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  command -v script &>/dev/null || _err "Missing 'script' command; cannot record terminal transcript"

  local log_file="$session_dir/terminal_work.log"
  local slug=$(jq -r '.slug' "$session_dir/meta.json")

  _section "Recording terminal work for: $slug"
  _info "Transcript file: ${log_file#$root/}"
  _info "Type 'exit' to stop recording and return to your shell"

  # script opens a nested interactive shell and records commands + output.
  script -q "$log_file"

  _ok "Saved terminal transcript: ${log_file#$root/}"
}

# ── wit event ─────────────────────────────────────────────────────────────────
cmd_event() {
  [[ $# -lt 1 ]] && _err "Usage: wit event <name> [value]\n  e.g. wit event test.pass\n  e.g. wit event file.change src/app.ts"

  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local event_name=$1
  shift
  local event_value="${*:-}"
  local event_file="$session_dir/events.jsonl"
  local ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local session_slug=$(jq -r '.slug' "$session_dir/meta.json")

  local event_line
  if [[ -n "$event_value" ]]; then
    event_line=$(jq -nc \
      --arg ts "$ts" \
      --arg event "$event_name" \
      --arg value "$event_value" \
      --arg slug "$session_slug" \
      '{ts:$ts,event:$event,value:$value,slug:$slug}')
  else
    event_line=$(jq -nc \
      --arg ts "$ts" \
      --arg event "$event_name" \
      --arg slug "$session_slug" \
      '{ts:$ts,event:$event,slug:$slug}')
  fi

  echo "$event_line" >> "$event_file"
  _ok "Event saved: $event_name${event_value:+ ($event_value)}"
}

# ── wit new ───────────────────────────────────────────────────────────────────
cmd_new() {
  [[ $# -lt 1 ]] && _err "Usage: wit new <slug> [tags...] [--goal \"text\"] [--open] [--force]\n  e.g. wit new auth-flow backend jwt --goal \"Build JWT login\""

  local root=$(_wit_root)
  local slug=$1; shift
  local tags=()
  local goal=""
  local no_open=1
  local force_open_new=0

  while (( $# > 0 )); do
    case "$1" in
      --goal)
        shift
        [[ $# -lt 1 ]] && _err "Missing value for --goal"
        goal="$1"
        ;;
      --no-open)
        no_open=1
        ;;
      --open)
        no_open=0
        ;;
      --force)
        force_open_new=1
        ;;
      *)
        tags+=("$1")
        ;;
    esac
    shift
  done

  local date=$(date +%Y-%m-%d)
  local dir="$root/sessions/${date}_${slug}"

  local open_sessions=0
  for d in "$root/sessions"/*/; do
    [[ -f "$d/meta.json" ]] || continue
    local rel="sessions/$(basename "$d")"
    if git -C "$root" status --porcelain "$rel" | grep -q .; then
      (( open_sessions += 1 ))
    fi
  done
  if (( open_sessions > 0 && force_open_new == 0 )); then
    _err "You already have ${open_sessions} open session(s). Finish current work first with: wit commit\nOr run: wit status\nTo bypass intentionally: wit new <slug> ... --force"
  fi

  [[ -d "$dir" ]] && _err "Session already exists: $dir"

  _section "New session: $slug"
  mkdir -p "$dir"

  # ── prompt.md ──
  cat > "$dir/prompt.md" <<EOF
# $slug
_${date}_

## goal
${goal:-<!-- one sentence: what are you trying to build? -->}

## prompt
<!-- paste the exact prompt you sent — no cleanup -->

## followups
<!-- any clarifying prompts you sent after (leave blank if none) -->
EOF

  # ── meta.json ──
  local tags_json
  if [[ ${#tags[@]} -gt 0 ]]; then
    tags_json=$(printf '"%s",' "${tags[@]}" | sed 's/,$//')
    tags_json="[$tags_json]"
  else
    tags_json='[]'
  fi

  cat > "$dir/meta.json" <<EOF
{
  "date": "$date",
  "slug": "$slug",
  "started_at": "$(_iso_now_utc)",
  "ended_at": null,
  "goal": null,
  "skill_areas": $tags_json,
  "prompt_score": null,
  "code_score": null,
  "drift_score": null,
  "session_score": null,
  "delta_from_raw": null,
  "iterations": null,
  "time_mins": null,
  "first_output_kept": null,
  "scoring_mode": null,
  "score_reasoning": null
}
EOF

  # ── output files ──
  touch "$dir/output_raw.txt"
  touch "$dir/output_final.txt"

  cat > "$dir/provenance.md" <<'EOF'
# Prompt Provenance Log

This file keeps exact prompt and response history for this session.

Use wit prompt and wit response so records stay consistent.
EOF

  if [[ -n "$goal" ]]; then
    local tmp=$(mktemp)
    jq --arg goal "$goal" '.goal=$goal' "$dir/meta.json" > "$tmp" && mv "$tmp" "$dir/meta.json"
  fi

  # ── reflection.md ──
  cat > "$dir/reflection.md" <<EOF
# reflection — $slug
_${date}_

## what worked
<!-- prompt patterns or framing that landed well -->

## what failed
<!-- where the prompt was vague, where code needed fixing -->

## pattern noticed
<!-- any recurring signal across sessions (optional) -->

## next experiment
<!-- one concrete thing to try differently next time -->
EOF

  _set_current_session "$root" "$dir"

  _ok "Scaffolded: sessions/${date}_${slug}/"
  _info "Work normally, then run: wit score && wit commit"

  # open in VS Code
  if (( no_open == 1 )); then
    _info "No editor opened by default. Use --open if you want to open it."
    _info "Session path: $dir"
  elif command -v code &>/dev/null; then
    code "$dir"
    _ok "Opened in VS Code"
  else
    _warn "VS Code CLI (code) not found — open the folder manually"
    _info "$dir"
  fi
}

# ── wit goal ──────────────────────────────────────────────────────────────────
cmd_goal() {
  [[ $# -lt 1 ]] && _err "Usage: wit goal <text>"

  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")

  local goal_text="$*"
  local meta="$session_dir/meta.json"
  local prompt_file="$session_dir/prompt.md"
  local tmp=$(mktemp)

  jq --arg goal "$goal_text" '.goal=$goal' "$meta" > "$tmp" && mv "$tmp" "$meta"

  if [[ -f "$prompt_file" ]]; then
    awk -v g="$goal_text" '
      BEGIN { in_goal=0; wrote=0 }
      /^##[[:space:]]+goal[[:space:]]*$/ {
        print
        print g
        in_goal=1
        wrote=1
        next
      }
      /^##[[:space:]]+/ {
        if (in_goal) in_goal=0
      }
      {
        if (!in_goal) print
      }
      END {
        if (!wrote) {
          print ""
          print "## goal"
          print g
        }
      }
    ' "$prompt_file" > "$tmp" && mv "$tmp" "$prompt_file"
  fi

  _ok "Goal updated for current open session"
}

# ── wit prompt / wit response ────────────────────────────────────────────────
cmd_prompt() {
  [[ $# -lt 1 ]] && _err "Usage: wit prompt [--model <name>] [--send-local] [--capture-only] <text>"
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")

  local model="${WIT_PROMPT_MODEL:-llama3.2:3b}"
  local send_local=0
  local capture_only=0
  while (( $# > 0 )); do
    case "$1" in
      --model)
        shift
        [[ $# -lt 1 ]] && _err "Missing value for --model"
        model="$1"
        ;;
      --send-local)
        send_local=1
        ;;
      --capture-only)
        capture_only=1
        ;;
      --)
        shift
        break
        ;;
      -*)
        _err "Unknown argument for wit prompt: $1"
        ;;
      *)
        break
        ;;
    esac
    shift
  done

  [[ $# -lt 1 ]] && _err "Usage: wit prompt [--model <name>] [--send-local] [--capture-only] <text>"

  local prompt_text="$*"
  local responses_file="$normalized_session_dir/responses.jsonl"
  local payload_file="$normalized_session_dir/last_prompt_payload.txt"
  local raw_file="$normalized_session_dir/output_raw.txt"
  local ts=$(_iso_now_utc)
  local slug
  slug=$(jq -r '.slug' "$normalized_session_dir/meta.json")

  _record_prompt_entry "$root" "$normalized_session_dir" "$prompt_text"

  local payload
  payload=$(_build_prompt_payload "$root" "$prompt_text")
  print -r -- "$payload" > "$payload_file"
  _info "Context payload saved: ${payload_file#$root/}"

  if (( capture_only == 1 || send_local == 0 )); then
    if (( send_local == 0 )); then
      _info "Use: wit context --copy \"<prompt>\" to send this context to external chat agents"
    fi
    _ok "Prompt captured"
    return 0
  fi

  if ! command -v ollama &>/dev/null; then
    _warn "Ollama not found; prompt captured only. Use --capture-only or install Ollama to auto-send."
    _ok "Prompt captured"
    return 0
  fi

  local response_text
  if ! response_text=$(print -r -- "$payload" | ollama run "$model" 2>/dev/null); then
    _warn "Ollama prompt send failed for model '$model'. Prompt was captured; run wit response manually if needed."
    _ok "Prompt captured"
    return 0
  fi

  jq -nc --arg ts "$ts" --arg slug "$slug" --arg response "$response_text" --arg model "$model" \
    '{ts:$ts,slug:$slug,response:$response,model:$model,source:"wit.prompt"}' >> "$responses_file"
  _append_provenance_record "$normalized_session_dir" "RESPONSE" "$response_text"

  {
    echo ""
    echo "## $ts MODEL_RESPONSE ($model)"
    echo ""
    print -r -- "$response_text"
  } >> "$raw_file"

  _ok "Model response captured"
  print -r -- "$response_text"

  _ok "Prompt captured"
}

cmd_capture_prompt() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")

  local prompt_text=""
  if (( $# > 0 )); then
    prompt_text="$*"
  else
    local pending_file="$normalized_session_dir/pending_prompt.txt"
    [[ -f "$pending_file" ]] || _err "No pending prompt found. Use: wit context --copy \"<prompt>\" first, or pass text to wit capture-prompt."
    prompt_text=$(cat "$pending_file")
  fi

  [[ -z "${prompt_text//[[:space:]]/}" ]] && _err "Prompt text is empty."
  _record_prompt_entry "$root" "$normalized_session_dir" "$prompt_text"
  _ok "Prompt captured"
}

cmd_context() {
  [[ $# -lt 1 ]] && _err "Usage: wit context [--copy] <text>"
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")
  local copy_to_clipboard=0

  while (( $# > 0 )); do
    case "$1" in
      --copy)
        copy_to_clipboard=1
        ;;
      --)
        shift
        break
        ;;
      -*)
        _err "Unknown argument for wit context: $1"
        ;;
      *)
        break
        ;;
    esac
    shift
  done

  [[ $# -lt 1 ]] && _err "Usage: wit context [--copy] <text>"
  local user_prompt="$*"
  local payload
  payload=$(_build_prompt_payload "$root" "$user_prompt")

  print -r -- "$payload" > "$normalized_session_dir/last_prompt_payload.txt"
  print -r -- "$user_prompt" > "$normalized_session_dir/pending_prompt.txt"
  _info "Context payload saved: sessions/$(basename "$normalized_session_dir")/last_prompt_payload.txt"
  _info "Pending prompt saved: sessions/$(basename "$normalized_session_dir")/pending_prompt.txt"

  if (( copy_to_clipboard == 1 )); then
    if command -v pbcopy &>/dev/null; then
      print -r -- "$payload" | pbcopy
      _ok "Context copied to clipboard"
      return 0
    fi
    _warn "pbcopy not found; printing payload instead"
  fi

  print -r -- "$payload"
}

cmd_response() {
  [[ $# -lt 1 ]] && _err "Usage: wit response <text>"
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local response_text="$*"
  local responses_file="$session_dir/responses.jsonl"
  local final_file="$session_dir/output_final.txt"
  local ts=$(_iso_now_utc)
  local slug
  slug=$(jq -r '.slug' "$session_dir/meta.json")

  jq -nc --arg ts "$ts" --arg slug "$slug" --arg response "$response_text" '{ts:$ts,slug:$slug,response:$response}' >> "$responses_file"
  _append_provenance_record "$session_dir" "RESPONSE" "$response_text"

  # Keep output_final in sync with captured responses for a simpler workflow.
  [[ -f "$final_file" ]] || : > "$final_file"
  if (( $(_nonempty_lines_file "$final_file") == 0 )); then
    print -r -- "$response_text" > "$final_file"
  else
    {
      echo ""
      echo "## $ts RESPONSE"
      echo ""
      print -r -- "$response_text"
    } >> "$final_file"
  fi

  _ok "Response captured"
  _info "Updated output evidence: ${final_file#$root/}"
}

# ── wit score ─────────────────────────────────────────────────────────────────
cmd_score() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local meta="$session_dir/meta.json"
  local slug=$(jq -r '.slug' "$meta")

  _section "Auto-scoring session: $slug"
  _autofill_output_final_if_empty "$root" "$session_dir"
  _score_session_heuristic "$session_dir"

  local prompt_score=$(jq -r '.prompt_score' "$meta")
  local code_score=$(jq -r '.code_score' "$meta")
  local drift_score=$(jq -r '.drift_score' "$meta")
  local session_score=$(jq -r '.session_score' "$meta")

  _ok "Scores updated (heuristic)"
  _info "prompt ${prompt_score}/10 · code ${code_score}/10 · drift ${drift_score}/10 · session ${session_score}/10"
}

# ── wit review ────────────────────────────────────────────────────────────────
cmd_review() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")
  [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"

  local model="${WIT_OLLAMA_MODEL:-llama3.2:3b}"
  while (( $# > 0 )); do
    case "$1" in
      --model)
        shift
        [[ $# -lt 1 ]] && _err "Missing value for --model"
        model="$1"
        ;;
      *)
        _err "Unknown argument for wit review: $1"
        ;;
    esac
    shift
  done

  local meta="$session_dir/meta.json"
  local slug
  slug=$(jq -r '.slug' "$meta")

  _section "LLM code review: $slug"
  _info "Model: $model"
  _run_ollama_review "$root" "$session_dir" "$model"

  local score
  local risk
  score=$(jq -r '.review_score' "$meta")
  risk=$(jq -r '.review_risk' "$meta")
  _ok "Review stored in session metadata"
  _info "review ${score}/10 · risk ${risk}"
}

# ── wit commit ────────────────────────────────────────────────────────────────
cmd_commit() {
  local root=$(_wit_root)
  local session_dir=$(_latest_open_session "$root")

  [[ -z "$session_dir" ]] && _err "No uncommitted session found. Start one with: wit new <slug>"

  local meta="$session_dir/meta.json"
  local slug=$(jq -r '.slug' "$meta")
  local date=$(jq -r '.date' "$meta")

  _section "Committing session: $slug"

  if command -v ollama &>/dev/null; then
    local model="${WIT_OLLAMA_MODEL:-llama3.2:3b}"
    _info "Running local LLM review with Ollama ($model)..."
    if ! _run_ollama_review "$root" "$session_dir" "$model"; then
      _warn "LLM review failed; continuing with heuristic scoring only"
    fi
  else
    _warn "Ollama not found; skipping LLM review"
  fi

  _info "Auto-scoring with heuristic model..."
  _autofill_output_final_if_empty "$root" "$session_dir"
  _score_session_heuristic "$session_dir"
  _session_metrics_autofill "$session_dir"

  local prompt_score
  local code_score
  local drift_score
  local session_score
  local iterations
  local time_mins
  local first_kept
  local delta
  prompt_score=$(jq -r '.prompt_score' "$meta")
  code_score=$(jq -r '.code_score' "$meta")
  drift_score=$(jq -r '.drift_score' "$meta")
  session_score=$(jq -r '.session_score' "$meta")
  iterations=$(jq -r '.iterations' "$meta")
  time_mins=$(jq -r '.time_mins' "$meta")
  first_kept=$(jq -r '.first_output_kept' "$meta")
  delta=$(jq -r '.delta_from_raw' "$meta")

  # ── append to scores.jsonl ──
  local areas=$(jq -c '.skill_areas' "$meta")
  local scoring_mode=$(jq -r '.scoring_mode // "manual"' "$meta")
  local score_reasoning=$(jq -r '.score_reasoning // ""' "$meta")
  local score_line=$(jq -nc \
    --arg date "$date" \
    --arg slug "$slug" \
    --argjson ps "$prompt_score" \
    --argjson cs "$code_score" \
    --argjson ds "$drift_score" \
    --argjson ss "$session_score" \
    --argjson it "$iterations" \
    --argjson tm "$time_mins" \
    --argjson fk "$first_kept" \
    --argjson dr "$delta" \
    --arg mode "$scoring_mode" \
    --arg reason "$score_reasoning" \
    --argjson areas "$areas" \
    '{date:$date,slug:$slug,prompt_score:$ps,code_score:$cs,drift_score:$ds,session_score:$ss,iterations:$it,time_mins:$tm,first_output_kept:$fk,delta_from_raw:$dr,scoring_mode:$mode,score_reasoning:$reason,skill_areas:$areas}')

  echo "$score_line" >> "$root/metrics/scores.jsonl"
  _ok "Appended to metrics/scores.jsonl"

  # ── git commit ──
  local areas_flat=$(jq -r '.skill_areas[]?' "$meta" | tr '\n' ' ' | sed 's/ $//')
  local msg="session: $date | $slug | prompt ${prompt_score}/10 code ${code_score}/10"
  [[ -n "$areas_flat" ]] && msg="$msg | $areas_flat"

  git -C "$root" add .
  git -C "$root" commit -m "$msg"
  _ok "git commit: $msg"
}

# ── wit log ───────────────────────────────────────────────────────────────────
cmd_log() {
  local root=$(_wit_root)
  local scores="$root/metrics/scores.jsonl"

  [[ ! -f "$scores" ]] && _err "No scores.jsonl found. Run wit init first."
  [[ ! -s "$scores" ]]  && { _warn "No sessions committed yet."; return; }

  _section "Session history"

  local count=0
  local total_prompt=0
  local total_code=0

  while IFS= read -r line; do
    local date=$(echo "$line" | jq -r '.date')
    local slug=$(echo "$line" | jq -r '.slug')
    local ps=$(echo "$line"   | jq -r '.prompt_score')
    local cs=$(echo "$line"   | jq -r '.code_score')
    local ds=$(echo "$line"   | jq -r '.drift_score // "--"')
    local ss=$(echo "$line"   | jq -r '.session_score // "--"')
    local it=$(echo "$line"   | jq -r '.iterations')
    local tm=$(echo "$line"   | jq -r '.time_mins')
    local mode=$(echo "$line" | jq -r '.scoring_mode // "manual"')
    local areas=$(echo "$line" | jq -r '.skill_areas[]?' | tr '\n' ' ')

    # score colour
    local p_col=$RESET
    local c_col=$RESET
    (( ps >= 8 )) && p_col=$GREEN || (( ps >= 6 )) && p_col=$YELLOW || p_col=$RED
    (( cs >= 8 )) && c_col=$GREEN || (( cs >= 6 )) && c_col=$YELLOW || c_col=$RED

    printf "  ${DIM}%s${RESET}  ${BOLD}%-24s${RESET}  prompt ${p_col}%2s/10${RESET}  code ${c_col}%2s/10${RESET}  drift %2s/10  session %2s/10  ${DIM}%s · %s iter · %s min · %s${RESET}\n" \
      "$date" "$slug" "$ps" "$cs" "$ds" "$ss" "$mode" "$it" "$tm" "$areas"

    (( count += 1 ))
    (( total_prompt += ps ))
    (( total_code   += cs ))
  done < "$scores"

  # averages
  if (( count > 0 )); then
    local avg_p=$(echo "scale=1; $total_prompt / $count" | bc)
    local avg_c=$(echo "scale=1; $total_code   / $count" | bc)
    _section "Averages across $count sessions"
    printf "  prompt %.1f/10   code %.1f/10\n" "$avg_p" "$avg_c"
  fi

  # trend (last 5 vs previous 5)
  if (( count >= 6 )); then
    _section "Trend (last 5 vs previous 5)"
    local last5=$(tail -5  "$scores" | jq -s '[.[].prompt_score] | add/length')
    local prev5=$(tail -10 "$scores" | head -5 | jq -s '[.[].prompt_score] | add/length')
    local diff=$(echo "scale=1; $last5 - $prev5" | bc)
    if (( $(echo "$diff > 0" | bc -l) )); then
      printf "  prompt ${GREEN}+%s${RESET} vs prior 5 sessions\n" "$diff"
    elif (( $(echo "$diff < 0" | bc -l) )); then
      printf "  prompt ${RED}%s${RESET} vs prior 5 sessions\n" "$diff"
    else
      printf "  prompt ${DIM}flat${RESET} vs prior 5 sessions\n"
    fi
  fi
}

# ── wit status ────────────────────────────────────────────────────────────────
cmd_status() {
  local root=$(_wit_root)
  local active_session=""
  active_session=$(_latest_open_session "$root" || true)

  _section "wit status"

  # uncommitted session folders
  local found=0
  local open_count=0
  for d in "$root/sessions"/*/; do
    [[ -f "$d/meta.json" ]] || continue
    local rel="sessions/$(basename $d)"
    if git -C "$root" status --porcelain "$rel" | grep -q .; then
      local slug=$(jq -r '.slug' "$d/meta.json")
      local ps=$(jq -r '.prompt_score' "$d/meta.json")
      local label="Open session"
      [[ "${d%/}" == "${active_session%/}" ]] && label="Active session"
      _info "${label}: ${BOLD}$slug${RESET} $([ "$ps" = "null" ] && echo "${YELLOW}(not yet scored)${RESET}" || echo "prompt ${ps}/10")"
      found=1
      (( open_count += 1 ))
    fi
  done

  if (( open_count > 1 )); then
    _warn "Multiple open sessions detected ($open_count). Recommended: work one session at a time."
  fi

  (( found == 0 )) && _ok "Nothing open. Start one with: wit new <slug> [tags...]"

  # quick git status
  echo ""
  git -C "$root" status --short
}

