#!/usr/bin/env zsh
# wit — skill tracking CLI
# mirrors git's vocabulary, sits alongside it
# usage: wit new <slug> [tags...]  |  wit commit  |  wit log  |  wit status

set -euo pipefail
setopt typeset_silent

# ── colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── helpers ───────────────────────────────────────────────────────────────────
_info()    { print -P "%F{cyan}→%f $*" }
_ok()      { print -P "%F{green}✓%f $*" }
_warn()    { print -P "%F{yellow}⚠%f $*" }
_err()     { print -P "%F{red}✗%f $*" >&2; exit 1 }
_section() { print -P "\n%B%F{blue}$*%f%b" }

# ── repo root detection ───────────────────────────────────────────────────────
_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

_wit_root() {
  local root
  root=$(_repo_root) || _err "Not inside a git repo. Run: git init"
  echo "$root"
}

_current_session_file() {
  local root=$1
  echo "$root/.wit/current_session"
}

_set_current_session() {
  local root=$1
  local session_dir=$2
  local current_file
  current_file=$(_current_session_file "$root")
  mkdir -p "$root/.wit"
  print -r -- "$(basename "$session_dir")" > "$current_file"
}

_latest_open_session_by_mtime() {
  local root=$1
  local session_dir=""
  local latest_time=0

  for d in "$root/sessions"/*/; do
    [[ -f "$d/meta.json" ]] || continue
    local rel="sessions/$(basename "$d")"
    if git -C "$root" status --porcelain "$rel" | grep -q .; then
      local mtime=$(stat -f %m "$d/meta.json" 2>/dev/null || stat -c %Y "$d/meta.json" 2>/dev/null)
      if (( mtime > latest_time )); then
        latest_time=$mtime
        session_dir=$d
      fi
    fi
  done

  [[ -n "$session_dir" ]] && echo "$session_dir"
}

_latest_open_session() {
  local root=$1
  local current_file
  current_file=$(_current_session_file "$root")

  if [[ -f "$current_file" ]]; then
    local current_base
    current_base=$(cat "$current_file" 2>/dev/null || true)
    if [[ -n "${current_base//[[:space:]]/}" ]]; then
      local current_dir="$root/sessions/$current_base"
      if [[ -f "$current_dir/meta.json" ]]; then
        local rel="sessions/$current_base"
        if git -C "$root" status --porcelain "$rel" | grep -q .; then
          echo "$current_dir"
          return
        fi
      fi
    fi
  fi

  local fallback
  fallback=$(_latest_open_session_by_mtime "$root")
  if [[ -n "${fallback//[[:space:]]/}" ]]; then
    _set_current_session "$root" "$fallback"
    echo "$fallback"
  fi
}

_clamp_1_10() {
  local n=$1
  (( n < 1 )) && n=1
  (( n > 10 )) && n=10
  echo "$n"
}

_extract_section() {
  local file=$1
  local header=$2
  [[ -f "$file" ]] || return 0
  awk -v h="$header" '
    BEGIN { in_section=0 }
    $0 ~ "^##[[:space:]]+" h "[[:space:]]*$" { in_section=1; next }
    /^##[[:space:]]+/ { if (in_section) exit }
    { if (in_section) print }
  ' "$file"
}

_word_count_text() {
  local text=$1
  LC_ALL=C print -r -- "$text" | LC_ALL=C tr -cs '[:alnum:]' '\n' | awk 'NF { c++ } END { print c+0 }'
}

_nonempty_lines_file() {
  local file=$1
  [[ -f "$file" ]] || { echo 0; return; }
  awk 'NF { c++ } END { print c+0 }' "$file"
}

_token_overlap_percent() {
  local a=$1
  local b=$2
  local fa=$(mktemp)
  local fb=$(mktemp)
  LC_ALL=C print -r -- "$a" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -cs '[:alnum:]' '\n' | awk 'length($0)>=3' | sort -u > "$fa"
  LC_ALL=C print -r -- "$b" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C tr -cs '[:alnum:]' '\n' | awk 'length($0)>=3' | sort -u > "$fb"

  local common=$(comm -12 "$fa" "$fb" | wc -l | tr -d ' ')
  local total=$(cat "$fa" "$fb" | sort -u | wc -l | tr -d ' ')
  rm -f "$fa" "$fb"

  [[ -z "$common" ]] && common=0
  [[ -z "$total" ]] && total=0

  if (( total == 0 )); then
    echo 50
    return
  fi

  echo $(( (common * 100) / total ))
}

_extract_first_json_object() {
  local input=$1
  print -r -- "$input" | awk '
    BEGIN { start=0; depth=0 }
    {
      line=$0
      for (i=1; i<=length(line); i++) {
        c=substr(line,i,1)
        if (!start && c=="{") start=1
        if (start) {
          printf "%s", c
          if (c=="{") depth++
          else if (c=="}") {
            depth--
            if (depth==0) exit
          }
        }
      }
      if (start) printf "\n"
    }
  '
}

_wit_config_file() {
  local root=$1
  echo "$root/.wit/config.json"
}

_ensure_wit_config() {
  local root=$1
  mkdir -p "$root/.wit"
  local cfg
  cfg=$(_wit_config_file "$root")
  if [[ ! -f "$cfg" ]]; then
    cat > "$cfg" <<'EOF'
{
  "auto_snapshot_on_prompt": true
}
EOF
  fi
}

_auto_snapshot_enabled() {
  local root=$1
  _ensure_wit_config "$root"
  local cfg
  cfg=$(_wit_config_file "$root")
  jq -e '.auto_snapshot_on_prompt // true' "$cfg" >/dev/null 2>&1
}

_set_auto_snapshot_enabled() {
  local root=$1
  local enabled=$2  wit review --model llama3.2:3b
  wit score
  wit explain api-setup
  _ensure_wit_config "$root"
  local cfg
  cfg=$(_wit_config_file "$root")
  local tmp
  tmp=$(mktemp)
  jq --argjson enabled "$enabled" '.auto_snapshot_on_prompt=$enabled' "$cfg" > "$tmp" && mv "$tmp" "$cfg"
}

_read_repo_context_file() {
  local root=$1
  local rel=$2
  local abs="$root/$rel"
  [[ -f "$abs" ]] || return 0

  echo "[$rel]"
  sed -n '1,400p' "$abs"
  echo ""
}

_build_prompt_payload() {
  local root=$1
  local user_prompt=$2

  {
    echo "=== REPOSITORY CONTEXT ==="
    _read_repo_context_file "$root" "AGENTS.md"
    echo "=== END REPOSITORY CONTEXT ==="
    echo ""
    echo "=== USER PROMPT ==="
    print -r -- "$user_prompt"
  }
}

_update_prompt_section() {
  local prompt_file=$1
  local new_prompt=$2
  [[ -f "$prompt_file" ]] || return 0

  local tmp
  tmp=$(mktemp)
  awk -v p="$new_prompt" '
    BEGIN { in_prompt=0; wrote=0 }
    /^##[[:space:]]+prompt[[:space:]]*$/ {
      print
      print p
      in_prompt=1
      wrote=1
      next
    }
    /^##[[:space:]]+/ {
      if (in_prompt) in_prompt=0
    }
    {
      if (!in_prompt) print
    }
    END {
      if (!wrote) {
        print ""
        print "## prompt"
        print p
      }
    }
  ' "$prompt_file" > "$tmp" && mv "$tmp" "$prompt_file"
}

_autofill_output_final_if_empty() {
  local root=$1
  local session_dir=$2
  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")
  local final_file="$normalized_session_dir/output_final.txt"

  [[ -f "$final_file" ]] || : > "$final_file"
  if (( $(_nonempty_lines_file "$final_file") > 0 )); then
    return 0
  fi

  local files
  files=$(git -C "$root" diff --name-only -- . ':(exclude)sessions/**' ':(exclude)metrics/**' 2>/dev/null || true)
  local untracked
  untracked=$(git -C "$root" ls-files --others --exclude-standard 2>/dev/null | grep -Ev '^(sessions/|metrics/)' || true)
  local merged
  merged=$(printf "%s\n%s\n" "$files" "$untracked" | awk 'NF' | awk '!seen[$0]++')

  [[ -z "${merged//[[:space:]]/}" ]] && return 0

  {
    echo "# AUTO-EVIDENCE"
    echo "# Populated by wit from changed workspace files because output_final.txt was empty"
    echo ""
    while IFS= read -r rel; do
      [[ -z "$rel" ]] && continue
      local abs="$root/$rel"
      [[ -f "$abs" ]] || continue

      # Ignore common generated/artifact paths that add noise to evidence.
      case "$rel" in
        .git/*|.venv/*|venv/*|node_modules/*|dist/*|build/*|target/*|coverage/*|.pytest_cache/*|__pycache__/*|*/__pycache__/*)
          continue
          ;;
      esac

      # Ignore common binary/compiled artifact extensions.
      case "$rel" in
        *.pyc|*.pyo|*.so|*.dylib|*.a|*.o|*.class|*.jar|*.zip|*.gz|*.tar|*.tgz|*.7z|*.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.db|*.sqlite|*.sqlite3|*.woff|*.woff2|*.ttf|*.otf)
          continue
          ;;
      esac

      local mime
      mime=$(file -b --mime "$abs" 2>/dev/null || true)
      if [[ "$mime" == *"charset=binary"* ]]; then
        continue
      fi

      # Skip binary files to keep evidence text-safe and scoring stable.
      if ! LC_ALL=C grep -Iq . "$abs" 2>/dev/null; then
        continue
      fi

      echo "## $rel"
      sed -n '1,260p' "$abs"
      local lc
      lc=$(wc -l < "$abs" | tr -d ' ')
      if (( lc > 260 )); then
        echo "[TRUNCATED: showing first 260 lines of $lc]"
      fi
      echo ""
    done <<< "$merged"
  } > "$final_file"

  _info "Auto-filled output evidence: ${final_file#$root/}"
}

_record_prompt_entry() {
  local root=$1
  local session_dir=$2
  local prompt_text=$3

  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")

  local prompts_file="$normalized_session_dir/prompts.jsonl"
  local ts=$(_iso_now_utc)
  local slug
  slug=$(jq -r '.slug' "$normalized_session_dir/meta.json")

  jq -nc --arg ts "$ts" --arg slug "$slug" --arg prompt "$prompt_text" '{ts:$ts,slug:$slug,prompt:$prompt}' >> "$prompts_file"
  _append_provenance_record "$normalized_session_dir" "PROMPT" "$prompt_text"
  _update_prompt_section "$normalized_session_dir/prompt.md" "$prompt_text"

  if _auto_snapshot_enabled "$root"; then
    local snapshot_path=""
    snapshot_path=$(_capture_session_snapshot "$root" "$normalized_session_dir" "prompt" || true)
    if [[ -n "${snapshot_path//[[:space:]]/}" ]]; then
      _info "Snapshot captured: ${snapshot_path#$root/}"
    else
      _info "No code changes detected for snapshot"
    fi
  fi
}

_capture_session_snapshot() {
  local root=$1
  local session_dir=$2
  local trigger=${3:-manual}

  local unstaged
  local staged
  local untracked

  unstaged=$(git -C "$root" diff --binary -- . ':(exclude)sessions/**' ':(exclude)metrics/**' 2>/dev/null || true)
  staged=$(git -C "$root" diff --binary --cached -- . ':(exclude)sessions/**' ':(exclude)metrics/**' 2>/dev/null || true)
  untracked=$(git -C "$root" ls-files --others --exclude-standard 2>/dev/null | grep -Ev '^(sessions/|metrics/)' || true)

  if [[ -z "${unstaged//[[:space:]]/}" && -z "${staged//[[:space:]]/}" && -z "${untracked//[[:space:]]/}" ]]; then
    return 1
  fi

  local normalized_session_dir
  normalized_session_dir=$(_normalize_session_path "$session_dir")
  local snapshots_dir="$normalized_session_dir/snapshots"
  mkdir -p "$snapshots_dir"
  local count
  count=$(find "$snapshots_dir" -maxdepth 1 -type f -name '*.diff' | wc -l | tr -d ' ')
  local next=$(( count + 1 ))
  local id
  id=$(printf "%04d" "$next")
  local snapshot_file="$snapshots_dir/${id}_${trigger}.diff"

  local current_state
  current_state=$(mktemp)
  {
    if [[ -n "${staged//[[:space:]]/}" ]]; then
      echo "## staged diff"
      print -r -- "$staged"
      echo ""
    fi
    if [[ -n "${unstaged//[[:space:]]/}" ]]; then
      echo "## unstaged diff"
      print -r -- "$unstaged"
      echo ""
    fi
    if [[ -n "${untracked//[[:space:]]/}" ]]; then
      echo "## untracked files"
      print -r -- "$untracked"
      echo ""
      while IFS= read -r rel; do
        [[ -z "$rel" ]] && continue
        local abs="$root/$rel"
        [[ -f "$abs" ]] || continue
        echo "### file: $rel"
        sed -n '1,220p' "$abs"
        local line_count
        line_count=$(wc -l < "$abs" | tr -d ' ')
        if (( line_count > 220 )); then
          echo "[TRUNCATED: showing first 220 lines of $line_count]"
        fi
        echo ""
      done <<< "$untracked"
    fi
  } > "$current_state"

  local baseline_file="$snapshots_dir/.baseline_snapshot.txt"
  local snapshot_mode="full"
  local payload_file="$current_state"

  if [[ -f "$baseline_file" ]]; then
    local delta_state
    delta_state=$(mktemp)
    diff -u -a --label previous_snapshot --label current_snapshot "$baseline_file" "$current_state" > "$delta_state" || true
    if [[ ! -s "$delta_state" ]]; then
      rm -f "$current_state" "$delta_state"
      return 1
    fi
    snapshot_mode="incremental"
    payload_file="$delta_state"
  fi

  {
    echo "# wit snapshot"
    echo "# ts: $(_iso_now_utc)"
    echo "# trigger: $trigger"
    echo "# mode: $snapshot_mode"
    echo ""
    if [[ "$snapshot_mode" == "incremental" ]]; then
      echo "## delta since previous snapshot"
      echo ""
    fi
    cat "$payload_file"
  } > "$snapshot_file"

  cp "$current_state" "$baseline_file"
  rm -f "$current_state"
  if [[ "$payload_file" != "$current_state" ]]; then
    rm -f "$payload_file"
  fi

  echo "$snapshot_file"
}

_install_prompt_provenance_instructions() {
  local root=$1

  mkdir -p "$root/.github"
  mkdir -p "$root/.wit"

  local copilot_file="$root/.github/copilot-instructions.md"
  if [[ ! -f "$copilot_file" ]]; then
    cat > "$copilot_file" <<'EOF'
# Prompt Provenance Instructions

Always preserve prompt provenance in generated code outputs.

For every code response, include this header at the top of the output file or snippet:

PROMPT_PROVENANCE
- Prompt: <exact user prompt>
- Timestamp UTC: <iso timestamp>
- Tool/Model: <agent or model name>

Rules:
- Keep the prompt text exact; do not paraphrase.
- Keep code unchanged except for the provenance header.
- If a file already contains provenance, append a new block instead of replacing history.
EOF
  fi

  local agents_file="$root/AGENTS.md"
  if [[ ! -f "$agents_file" ]]; then
    cat > "$agents_file" <<'EOF'
# AGENTS

Repository policy: prompt provenance is mandatory.

When generating code:
1. Add a PROMPT_PROVENANCE block with exact prompt text and UTC timestamp.
2. Keep prompt and code together in project artifacts.
3. Do not remove previous provenance records from session artifacts.
EOF
  fi

  local claude_file="$root/CLAUDE.md"
  if [[ ! -f "$claude_file" ]]; then
    cat > "$claude_file" <<'EOF'
# Claude Project Instructions

Prompt provenance requirement:
- Every code artifact should preserve the exact originating prompt.
- Add a PROMPT_PROVENANCE block at the top of generated code outputs.
- Include Prompt, Timestamp UTC, and Tool/Model.
EOF
  fi

  local policy_file="$root/.wit/prompt-provenance.md"
  if [[ ! -f "$policy_file" ]]; then
    cat > "$policy_file" <<'EOF'
# wit Prompt Provenance Policy

Goal: Keep intent and implementation traceable.

Standard block:

PROMPT_PROVENANCE
- Prompt: <exact prompt text>
- Timestamp UTC: <iso timestamp>
- Tool/Model: <tool>

This repository stores prompt/response history in sessions/* files.
EOF
  fi
}

_append_provenance_record() {
  local session_dir=$1
  local kind=$2
  local text=$3

  local file="$session_dir/provenance.md"
  local ts=$(_iso_now_utc)

  if [[ ! -f "$file" ]]; then
    cat > "$file" <<'EOF'
# Prompt Provenance Log

This file keeps exact prompt and response history for this session.
EOF
  fi

  {
    echo ""
    echo "## $ts $kind"
    echo ""
    echo '```text'
    print -r -- "$text"
    echo '```'
  } >> "$file"
}

_normalize_session_path() {
  local p=$1
  while [[ "$p" == */ ]]; do
    p=${p%/}
  done
  echo "$p"
}

_run_ollama_review() {
  local root=$1
  local session_dir=$2
  local model=$3
  local meta="$session_dir/meta.json"

  command -v ollama &>/dev/null || _err "Ollama is not installed. Install from https://ollama.com and retry."

  local goal
  goal=$(jq -r '.goal // ""' "$meta")
  if [[ -z "${goal//[[:space:]]/}" ]]; then
    goal=$(_extract_section "$session_dir/prompt.md" "goal")
  fi

  local diff
  diff=$(git -C "$root" diff HEAD -- . ':(exclude)sessions/**' ':(exclude)metrics/**' 2>/dev/null || true)
  if [[ -z "${diff//[[:space:]]/}" ]]; then
    diff=$(git -C "$root" diff -- . ':(exclude)sessions/**' ':(exclude)metrics/**' 2>/dev/null || true)
  fi
  if [[ -z "${diff//[[:space:]]/}" ]]; then
    diff="No code diff detected outside wit tracking files."
  fi

  # Keep prompt size bounded for local models.
  if (( ${#diff} > 22000 )); then
    diff="${diff[1,22000]}\n\n[TRUNCATED]"
  fi

  local review_prompt_file
  review_prompt_file=$(mktemp)
  cat > "$review_prompt_file" <<EOF
You are a strict senior code reviewer.
Review the code changes against the goal and return ONLY JSON.

Scoring rubric (1-10):
- correctness: does it satisfy expected behavior?
- robustness: errors, edge cases, idempotency, retries.
- maintainability: readability, structure, naming, cohesion.
- security: validation, secrets handling, unsafe patterns.
- goal_alignment: how well it matches the goal.

Compute quality_score as strict weighted score:
quality_score = round(0.35*correctness + 0.20*robustness + 0.20*maintainability + 0.15*security + 0.10*goal_alignment)

Risk level:
- low, medium, high

Return JSON with this exact schema:
{
  "quality_score": 1,
  "risk_level": "low|medium|high",
  "summary": "short summary",
  "rubric": {
    "correctness": 1,
    "robustness": 1,
    "maintainability": 1,
    "security": 1,
    "goal_alignment": 1
  },
  "findings": [
    {"severity":"high|medium|low","title":"...","evidence":"...","recommendation":"..."}
  ]
}

Goal:
$goal

Git diff:
$diff
EOF

  local raw
  if ! raw=$(ollama run "$model" --format json < "$review_prompt_file" 2>/dev/null); then
    rm -f "$review_prompt_file"
    _err "Ollama review failed for model '$model'. Check that the model is pulled and running."
  fi
  rm -f "$review_prompt_file"

  local sanitized
  sanitized=$(print -r -- "$raw" | perl -pe 's/\e\[[0-9;?]*[ -\/]*[@-~]//g; s/\e\].*?(\a|\e\\)//g; s/\r//g; s/[\x00-\x08\x0B\x0C\x0E-\x1F]//g')

  local parsed
  parsed="$sanitized"
  if ! print -r -- "$parsed" | jq -e . >/dev/null 2>&1; then
    parsed=$(_extract_first_json_object "$sanitized")
  fi
  if print -r -- "$parsed" | jq -e '.response? != null' >/dev/null 2>&1; then
    local response_payload
    response_payload=$(print -r -- "$parsed" | jq -r '.response')
    if print -r -- "$response_payload" | jq -e . >/dev/null 2>&1; then
      parsed="$response_payload"
    else
      local extracted_payload
      extracted_payload=$(_extract_first_json_object "$response_payload")
      if [[ -n "${extracted_payload//[[:space:]]/}" ]] && print -r -- "$extracted_payload" | jq -e . >/dev/null 2>&1; then
        parsed="$extracted_payload"
      fi
    fi
  fi
  if [[ -z "${parsed//[[:space:]]/}" ]] || ! print -r -- "$parsed" | jq -e . >/dev/null 2>&1; then
    # Retry once by explicitly asking the model to normalize the prior response to JSON only.
    local repair_prompt_file
    repair_prompt_file=$(mktemp)
    cat > "$repair_prompt_file" <<EOF
You will receive text from a previous model response.
Extract and return ONLY a valid JSON object with this exact schema and no markdown fences.

{
  "quality_score": 1,
  "risk_level": "low|medium|high",
  "summary": "short summary",
  "rubric": {
    "correctness": 1,
    "robustness": 1,
    "maintainability": 1,
    "security": 1,
    "goal_alignment": 1
  },
  "findings": [
    {"severity":"high|medium|low","title":"...","evidence":"...","recommendation":"..."}
  ]
}

If fields are missing, infer best-effort defaults.

TEXT:
$raw
EOF

    local repaired
    repaired=$(ollama run "$model" --format json < "$repair_prompt_file" 2>/dev/null || true)
    rm -f "$repair_prompt_file"

    local repaired_sanitized
    repaired_sanitized=$(print -r -- "$repaired" | perl -pe 's/\e\[[0-9;?]*[ -\/]*[@-~]//g; s/\e\].*?(\a|\e\\)//g; s/\r//g; s/[\x00-\x08\x0B\x0C\x0E-\x1F]//g')

    parsed="$repaired_sanitized"
    if ! print -r -- "$parsed" | jq -e . >/dev/null 2>&1; then
      parsed=$(_extract_first_json_object "$repaired_sanitized")
    fi
    if print -r -- "$parsed" | jq -e '.response? != null' >/dev/null 2>&1; then
      local repaired_payload
      repaired_payload=$(print -r -- "$parsed" | jq -r '.response')
      if print -r -- "$repaired_payload" | jq -e . >/dev/null 2>&1; then
        parsed="$repaired_payload"
      else
        local repaired_extracted
        repaired_extracted=$(_extract_first_json_object "$repaired_payload")
        if [[ -n "${repaired_extracted//[[:space:]]/}" ]] && print -r -- "$repaired_extracted" | jq -e . >/dev/null 2>&1; then
          parsed="$repaired_extracted"
        fi
      fi
    fi
    if [[ -z "${parsed//[[:space:]]/}" ]] || ! print -r -- "$parsed" | jq -e . >/dev/null 2>&1; then
      local debug_file="$session_dir/review_raw_output.txt"
      print -r -- "$raw" > "$debug_file"
      _err "Ollama review did not return valid JSON. Raw output saved to: ${debug_file#$root/}"
    fi
  fi

  local quality
  local risk
  local summary
  quality=$(print -r -- "$parsed" | jq -r '
    if .quality_score != null then .quality_score
    elif .overall_score != null then .overall_score
    elif .score != null then .score
    elif .rating != null then .rating
    elif .rubric != null then
      (
        ((.rubric.correctness // .rubric.accuracy // 5) * 0.35)
        + ((.rubric.robustness // 5) * 0.20)
        + ((.rubric.maintainability // 5) * 0.20)
        + ((.rubric.security // 5) * 0.15)
        + ((.rubric.goal_alignment // .rubric.alignment // 5) * 0.10)
      ) | round
    elif .scores != null then
      (
        ((.scores.correctness // .scores.accuracy // 5) * 0.35)
        + ((.scores.robustness // 5) * 0.20)
        + ((.scores.maintainability // 5) * 0.20)
        + ((.scores.security // 5) * 0.15)
        + ((.scores.goal_alignment // .scores.alignment // 5) * 0.10)
      ) | round
    else null end')
  risk=$(print -r -- "$parsed" | jq -r '.risk_level // .risk // "medium"')
  summary=$(print -r -- "$parsed" | jq -r '.summary // .analysis // .comment // ""')

  if [[ "$quality" == "null" ]]; then
    local debug_file="$session_dir/review_raw_output.txt"
    print -r -- "$raw" > "$debug_file"
    _warn "Ollama review JSON had no score field. Falling back to quality_score=5. Raw output saved to: ${debug_file#$root/}"
    quality=5
  fi

  local rubric_json
  local findings_json
  rubric_json=$(print -r -- "$parsed" | jq -c '.rubric // .scores // {}')
  findings_json=$(print -r -- "$parsed" | jq -c '.findings // .issues // []')

  # Keep score in a valid 1-10 range even when models return odd values.
  if ! [[ "$quality" =~ '^[0-9]+$' ]]; then
    quality=$(print -r -- "$quality" | sed -E 's/[^0-9]//g')
  fi
  [[ -z "$quality" ]] && quality=5
  (( quality < 1 )) && quality=1
  (( quality > 10 )) && quality=10

  local tmp
  tmp=$(mktemp)
  jq \
    --argjson rs "$quality" \
    --arg rr "$risk" \
    --arg rsum "$summary" \
    --arg rmodel "$model" \
    --arg rts "$(_iso_now_utc)" \
    --argjson findings "$findings_json" \
    --argjson rubric "$rubric_json" \
    '.review_score=$rs
    | .review_risk=$rr
    | .review_summary=$rsum
    | .review_model=$rmodel
    | .review_ts=$rts
    | .review_findings=$findings
    | .review_rubric=$rubric' \
    "$meta" > "$tmp" && mv "$tmp" "$meta"
}

_iso_now_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

_seconds_between_iso() {
  local start=$1
  local end=$2
  local s_epoch
  local e_epoch

  s_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$start" "+%s" 2>/dev/null || true)
  e_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$end" "+%s" 2>/dev/null || true)

  if [[ -z "$s_epoch" || -z "$e_epoch" ]]; then
    echo 0
    return
  fi

  local diff=$(( e_epoch - s_epoch ))
  (( diff < 0 )) && diff=0
  echo "$diff"
}

_session_metrics_autofill() {
  local session_dir=$1
  local meta="$session_dir/meta.json"
  local events_file="$session_dir/events.jsonl"
  local prompts_file="$session_dir/prompts.jsonl"
  local raw_file="$session_dir/output_raw.txt"
  local final_file="$session_dir/output_final.txt"

  local started_at
  started_at=$(jq -r '.started_at // empty' "$meta")
  local ended_at=$(_iso_now_utc)

  local time_mins
  time_mins=$(jq -r '.time_mins' "$meta")
  if [[ "$time_mins" == "null" ]]; then
    if [[ -n "$started_at" ]]; then
      local secs=$(_seconds_between_iso "$started_at" "$ended_at")
      local mins=$(( (secs + 59) / 60 ))
      (( mins < 1 )) && mins=1
      time_mins=$mins
    else
      time_mins=1
    fi
  fi

  local iterations
  iterations=$(jq -r '.iterations' "$meta")
  if [[ "$iterations" == "null" ]]; then
    local event_count=0
    local prompt_count=0
    [[ -f "$events_file" ]] && event_count=$(wc -l < "$events_file" | tr -d ' ')
    [[ -f "$prompts_file" ]] && prompt_count=$(wc -l < "$prompts_file" | tr -d ' ')
    local total=$(( event_count + prompt_count ))
    if (( total <= 1 )); then
      iterations=1
    elif (( total <= 4 )); then
      iterations=2
    elif (( total <= 8 )); then
      iterations=3
    else
      iterations=4
    fi
  fi

  local delta
  delta=$(jq -r '.delta_from_raw' "$meta")
  if [[ "$delta" == "null" ]]; then
    local raw_lines=0
    local final_lines=0
    [[ -f "$raw_file" ]] && raw_lines=$(_nonempty_lines_file "$raw_file")
    [[ -f "$final_file" ]] && final_lines=$(_nonempty_lines_file "$final_file")
    if (( raw_lines == 0 )); then
      delta=0
    else
      local d=$(( final_lines - raw_lines ))
      (( d < 0 )) && d=$(( -d ))
      delta=$d
    fi
  fi

  local first_kept
  first_kept=$(jq -r '.first_output_kept' "$meta")
  if [[ "$first_kept" == "null" ]]; then
    if (( delta <= 2 )); then
      first_kept=true
    else
      first_kept=false
    fi
  fi

  local tmp
  tmp=$(mktemp)
  jq \
    --arg ended "$ended_at" \
    --argjson it "$iterations" \
    --argjson tm "$time_mins" \
    --argjson dr "$delta" \
    --argjson fk "$first_kept" \
    '.ended_at=$ended
    | .iterations=(if .iterations == null then $it else .iterations end)
    | .time_mins=(if .time_mins == null then $tm else .time_mins end)
    | .delta_from_raw=(if .delta_from_raw == null then $dr else .delta_from_raw end)
    | .first_output_kept=(if .first_output_kept == null then $fk else .first_output_kept end)' \
    "$meta" > "$tmp" && mv "$tmp" "$meta"
}

_score_session_heuristic() {
  local session_dir=$1
  local meta="$session_dir/meta.json"
  local prompt_file="$session_dir/prompt.md"
  local final_file="$session_dir/output_final.txt"
  local reflection_file="$session_dir/reflection.md"
  local events_file="$session_dir/events.jsonl"
  local prompts_file="$session_dir/prompts.jsonl"
  local responses_file="$session_dir/responses.jsonl"

  local goal_text=$(_extract_section "$prompt_file" "goal")
  if [[ -z "${goal_text//[[:space:]]/}" ]]; then
    goal_text=$(jq -r '.goal // ""' "$meta")
  fi
  local prompt_text=$(_extract_section "$prompt_file" "prompt")
  local prompt_log_text=""
  if [[ -f "$prompts_file" ]]; then
    prompt_log_text=$(jq -r '.prompt' "$prompts_file" 2>/dev/null | tr '\n' ' ')
  fi
  if [[ -n "${prompt_log_text//[[:space:]]/}" ]]; then
    prompt_text="$prompt_log_text"
  fi
  local followups_text=$(_extract_section "$prompt_file" "followups")
  local final_text=""
  [[ -f "$final_file" ]] && final_text=$(cat "$final_file")

  local goal_words=$(_word_count_text "$goal_text")
  local prompt_words=$(_word_count_text "$prompt_text")
  local followups_words=$(_word_count_text "$followups_text")
  local final_lines=$(_nonempty_lines_file "$final_file")

  local prompt_score=5
  (( goal_words >= 5 )) && (( prompt_score += 1 )) || (( prompt_score -= 1 ))
  (( prompt_words >= 25 )) && (( prompt_score += 1 ))
  (( prompt_words >= 70 )) && (( prompt_score += 1 ))
  print -r -- "$prompt_text" | grep -Eiq '(must|should|acceptance|criteria|output|format|constraint)' && (( prompt_score += 1 ))
  print -r -- "$prompt_text" | grep -Eiq '(language|framework|stack|api|file|test)' && (( prompt_score += 1 ))
  (( followups_words > 0 )) && (( prompt_score += 1 ))
  [[ -f "$prompts_file" ]] && (( prompt_score += 1 ))
  [[ -f "$responses_file" ]] && (( prompt_score += 1 ))
  prompt_score=$(_clamp_1_10 "$prompt_score")

  local code_score=5
  (( final_lines >= 8 )) && (( code_score += 1 ))
  (( final_lines >= 25 )) && (( code_score += 1 ))

  local worked_text=$(_extract_section "$reflection_file" "what worked")
  local failed_text=$(_extract_section "$reflection_file" "what failed")
  local pattern_text=$(_extract_section "$reflection_file" "pattern noticed")
  local next_text=$(_extract_section "$reflection_file" "next experiment")
  (( $(_word_count_text "$worked_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$failed_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$pattern_text") > 0 )) && (( code_score += 1 ))
  (( $(_word_count_text "$next_text") > 0 )) && (( code_score += 1 ))

  local pass_events=0
  local fail_events=0
  if [[ -f "$events_file" ]]; then
    pass_events=$(grep -Ec '"event":"(test.pass|build.pass)"' "$events_file" || true)
    fail_events=$(grep -Ec '"event":"(test.fail|build.fail)"' "$events_file" || true)
  fi
  (( pass_events > 0 )) && (( code_score += 1 ))
  (( fail_events > 0 )) && (( code_score -= 1 ))

  local first_kept=$(jq -r '.first_output_kept' "$meta")
  [[ "$first_kept" == "true" ]] && (( code_score += 1 ))

  local delta=$(jq -r '.delta_from_raw' "$meta")
  if [[ "$delta" != "null" ]]; then
    if (( delta <= 3 )); then
      (( code_score += 1 ))
    elif (( delta >= 10 )); then
      (( code_score -= 1 ))
    fi
  fi

  local iterations=$(jq -r '.iterations' "$meta")
  if [[ "$iterations" != "null" ]]; then
    (( iterations <= 2 )) && (( code_score += 1 ))
    (( iterations >= 6 )) && (( code_score -= 1 ))
  fi

  local review_score
  local review_risk
  review_score=$(jq -r '.review_score // null' "$meta")
  review_risk=$(jq -r '.review_risk // ""' "$meta")
  if [[ "$review_score" != "null" ]]; then
    # Strictly weight LLM review higher than heuristic proxies.
    code_score=$(( (code_score * 4 + review_score * 6 + 5) / 10 ))
    [[ "$review_risk" == "high" ]] && (( code_score -= 1 ))
  fi

  code_score=$(_clamp_1_10 "$code_score")

  local overlap=$(_token_overlap_percent "$goal_text" "$final_text")
  local drift_score=$(( overlap / 10 ))
  (( drift_score == 0 )) && drift_score=1
  print -r -- "$failed_text" | grep -Eiq '(drift|scope creep|changed direction|off track)' && (( drift_score -= 1 ))
  drift_score=$(_clamp_1_10 "$drift_score")

  local session_score=$(( (prompt_score + code_score + drift_score) / 3 ))
  session_score=$(_clamp_1_10 "$session_score")

  local reason="heuristic: prompt_words=$prompt_words, final_lines=$final_lines, overlap=${overlap}%, pass_events=$pass_events, fail_events=$fail_events"

  local tmp=$(mktemp)
  jq \
    --argjson ps "$prompt_score" \
    --argjson cs "$code_score" \
    --argjson ds "$drift_score" \
    --argjson ss "$session_score" \
    --arg mode "heuristic" \
    --arg reason "$reason" \
    '.prompt_score=$ps
    | .code_score=$cs
    | .drift_score=$ds
    | .session_score=$ss
    | .scoring_mode=$mode
    | .score_reasoning=$reason' \
    "$meta" > "$tmp" && mv "$tmp" "$meta"
}

# ── wit init ──────────────────────────────────────────────────────────────────
cmd_init() {
  local root=${1:-$PWD}
  _section "Initialising wit in $root"

  mkdir -p "$root/sessions"
  mkdir -p "$root/metrics"

  # scores.jsonl — the database
  if [[ ! -f "$root/metrics/scores.jsonl" ]]; then
    touch "$root/metrics/scores.jsonl"
    _ok "Created metrics/scores.jsonl"
  fi

  # trends.md — human-readable summary, updated by wit log
  if [[ ! -f "$root/metrics/trends.md" ]]; then
    cat > "$root/metrics/trends.md" <<'EOF'
# Trends

Updated automatically by `wit log`.

## Summary
_No sessions committed yet._
EOF
    _ok "Created metrics/trends.md"
  fi

  # README
  if [[ ! -f "$root/README.md" ]]; then
    cat > "$root/README.md" <<'EOF'
# skill-tracker

A git-based log of prompt and code quality over time.

## workflow
```
wit new <slug> [tags...]   # start a session
wit work                   # record terminal work into current session
wit event <name> [value]   # append a structured event to current session
wit commit                 # score + commit
wit log                    # view history
wit status                 # current open session
```

## session structure
```
sessions/YYYY-MM-DD_<slug>/
  prompt.md        — the exact prompt sent
  output_raw.*     — claude's output, unedited
  output_final.*   — what you actually kept
  meta.json        — scores, tags, timing
  reflection.md    — what worked / failed
```
EOF
    _ok "Created README.md"
  fi

  _install_prompt_provenance_instructions "$root"
  _ensure_wit_config "$root"
  _ok "Prompt provenance instructions installed"

  # initial commit if repo is empty
  if ! git -C "$root" log --oneline -1 &>/dev/null; then
    git -C "$root" add .
    git -C "$root" commit -m "init: wit scaffold"
    _ok "Initial commit done"
  fi

  _ok "wit ready. Start your first session with: wit new <slug> [tags...]"
}

cmd_install_instructions() {
