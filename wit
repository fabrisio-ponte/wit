"
}

cmd_snapshot() {
  local root=$(_wit_root)
  local action=${1:-status}

  case "$action" in
    status)
      if _auto_snapshot_enabled "$root"; then
        _info "auto snapshot on prompt: ON"
      else
        _info "auto snapshot on prompt: OFF"
      fi
      ;;
    on)
      _set_auto_snapshot_enabled "$root" true
      _ok "Auto snapshot on prompt enabled"
      ;;
    off)
      _set_auto_snapshot_enabled "$root" false
      _ok "Auto snapshot on prompt disabled"
      ;;
    now)
      local session_dir
      session_dir=$(_latest_open_session "$root")
      [[ -z "$session_dir" ]] && _err "No open session found. Start one with: wit new <slug>"
      local snapshot_path=""
      snapshot_path=$(_capture_session_snapshot "$root" "$session_dir" "manual" || true)
      if [[ -z "${snapshot_path//[[:space:]]/}" ]]; then
        _warn "No code changes detected"
      else
        _ok "Snapshot captured: ${snapshot_path#$root/}"
      fi
      ;;
    *)
      _err "Usage: wit snapshot [status|on|off|now]"
      ;;
  esac
}

# ── wit explain ───────────────────────────────────────────────────────────────
cmd_explain() {
  local root=$(_wit_root)
  local target_slug=${1:-}
  local session_dir=""

  if [[ -n "$target_slug" ]]; then
    for d in "$root/sessions"/*/; do
      [[ -f "$d/meta.json" ]] || continue
      local slug
      slug=$(jq -r '.slug // ""' "$d/meta.json")
      local base
      base=$(basename "$d")
      if [[ "$slug" == "$target_slug" || "$base" == "$target_slug" || "$base" == *"_$target_slug" ]]; then
        session_dir="$d"
      fi
    done
  else
    session_dir=$(_latest_open_session "$root")
    if [[ -z "$session_dir" ]]; then
      local latest_time=0
      for d in "$root/sessions"/*/; do
        [[ -f "$d/meta.json" ]] || continue
        local mtime
        mtime=$(stat -f %m "$d/meta.json" 2>/dev/null || stat -c %Y "$d/meta.json" 2>/dev/null)
        if (( mtime > latest_time )); then
          latest_time=$mtime
          session_dir=$d
        fi
      done
    fi
  fi

  [[ -z "$session_dir" ]] && _err "No matching session found. Try: wit explain <slug>"

  local meta="$session_dir/meta.json"
  local prompt_file="$session_dir/prompt.md"
  local final_file="$session_dir/output_final.txt"
  local slug
  local date
  slug=$(jq -r '.slug // "unknown"' "$meta")
  date=$(jq -r '.date // "unknown"' "$meta")

  local ps cs ds ss
  local mode reason
  ps=$(jq -r '.prompt_score // "null"' "$meta")
  cs=$(jq -r '.code_score // "null"' "$meta")
  ds=$(jq -r '.drift_score // "null"' "$meta")
  ss=$(jq -r '.session_score // "null"' "$meta")
  mode=$(jq -r '.scoring_mode // "unknown"' "$meta")
  reason=$(jq -r '.score_reasoning // ""' "$meta")

  local review_score review_risk review_summary
  review_score=$(jq -r '.review_score // "null"' "$meta")
  review_risk=$(jq -r '.review_risk // "n/a"' "$meta")
  review_summary=$(jq -r '.review_summary // ""' "$meta")

  local final_lines
  final_lines=$(_nonempty_lines_file "$final_file")

  local confidence="high"
  local warnings=()
  if (( final_lines == 0 )); then
    confidence="low"
    warnings+=("output_final.txt is empty, so overlap/output-based heuristics are weak")
  fi
  if [[ -f "$prompt_file" ]] && grep -Eq '<!--.*-->' "$prompt_file"; then
    [[ "$confidence" == "high" ]] && confidence="medium"
    warnings+=("prompt.md still contains template placeholders")
  fi
  if [[ "$review_score" == "null" ]]; then
    [[ "$confidence" == "high" ]] && confidence="medium"
    warnings+=("no LLM review score found in metadata")
  fi

  _section "Score explanation: $slug"
  printf "  date: %s\n" "$date"
  printf "  scoring mode: %s\n" "$mode"
  printf "  prompt: %s/10   code: %s/10   drift: %s/10   session: %s/10\n" "$ps" "$cs" "$ds" "$ss"
  if [[ "$ps" != "null" && "$cs" != "null" && "$ds" != "null" && "$ss" != "null" ]]; then
    printf "  formula: (%s + %s + %s) / 3 = %s\n" "$ps" "$cs" "$ds" "$ss"
  fi

  _section "Heuristic reason"
  if [[ -n "${reason//[[:space:]]/}" ]]; then
    printf "  %s\n" "$reason"
  else
    printf "  (none recorded)\n"
  fi

  _section "LLM review"
  printf "  score: %s/10   risk: %s\n" "$review_score" "$review_risk"
  [[ -n "${review_summary//[[:space:]]/}" ]] && printf "  summary: %s\n" "$review_summary"
  printf "  rubric:\n"
  jq -r '.review_rubric // {} | to_entries[]? | "    - \(.key): \(.value)/10"' "$meta"
  printf "  findings:\n"
  jq -r '.review_findings // [] | if length==0 then ["    - none"] else map("    - [\(.severity)] \(.title): \(.evidence)") end | .[]' "$meta"

  _section "Evidence confidence"
  printf "  confidence: %s\n" "$confidence"
  if (( ${#warnings[@]} > 0 )); then
    for w in "${warnings[@]}"; do
      printf "  - %s\n" "$w"
    done
  else
    printf "  - scoring evidence looks complete for this session\n"
  fi
}

