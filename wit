# ── router ────────────────────────────────────────────────────────────────────
local cmd=${1:-help}
shift 2>/dev/null || true

case $cmd in
  init)   cmd_init "$@"   ;;
  install-instructions) cmd_install_instructions "$@" ;;
  new)    cmd_new "$@"    ;;
  goal)   cmd_goal "$@"   ;;
  prompt) cmd_prompt "$@" ;;
  context) cmd_context "$@" ;;
  capture-prompt) cmd_capture_prompt "$@" ;;
  flow) cmd_flow ;;
  response) cmd_response "$@" ;;
  review) cmd_review "$@" ;;
  snapshot) cmd_snapshot "$@" ;;
  work)   cmd_work "$@"   ;;
  event)  cmd_event "$@"  ;;
  score)  cmd_score "$@"  ;;
  commit) cmd_commit "$@" ;;
  log)    cmd_log "$@"    ;;
  explain) cmd_explain "$@" ;;
  status) cmd_status "$@" ;;
  help|--help|-h) cmd_help ;;
  *) _err "Unknown command: $cmd\nRun: wit help" ;;
esac
