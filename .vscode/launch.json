{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Wit Bridge Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-wit-bridge",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-wit-bridge/out/**/*.js"
      ],
      "preLaunchTask": "compile-wit-bridge"
    }
  ]
}
